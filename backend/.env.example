# Application Settings
APP_NAME=AI Customer Support System
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your-secret-key-change-this-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# MongoDB Settings
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ai_support_system
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Google Gemini API
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Agent Settings
MAX_AGENT_ITERATIONS=5
AGENT_TIMEOUT=30
ESCALATION_CONFIDENCE_THRESHOLD=0.6
MAX_CONVERSATION_HISTORY=10

# Industry Configuration
DEFAULT_INDUSTRY=saas
SUPPORTED_INDUSTRIES=["ecommerce","saas","telecom"]

# WhatsApp Integration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Stripe Payment Gateway (Mock in development)
STRIPE_API_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# CRM Integration (Mock in development)
CRM_PROVIDER=mock
CRM_API_KEY=mock-crm-key
CRM_API_URL=https://api.mockcrm.com

# Shipping Providers (Mock in development)
SHIPPING_PROVIDER=mock
FEDEX_API_KEY=mock-fedex-key
UPS_API_KEY=mock-ups-key

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Ticket System
TICKET_PREFIX=T-
TICKET_NOTIFICATION_EMAIL=support@example.com

# Feature Flags
ENABLE_WHATSAPP=false
ENABLE_WEB_CHAT=true
ENABLE_REAL_INTEGRATIONS=false
ENABLE_VECTOR_SEARCH=true

# Logging
LOG_FILE_PATH=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
